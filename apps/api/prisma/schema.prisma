// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  MOVIE
  SERIES
}

enum EventType {
  GALA_PREMIERE
  STANDUP_COMEDY
  CONCERT
  SPECIAL_EVENT
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password_hash String
  full_name    String?
  avatar_url   String?
  local_avatar_url String?    // For uploaded avatars
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  watchlist    Watchlist[]
  watch_progress WatchProgress[]
  subscriptions UserSubscription[]
  rentals      UserRental[]
  event_tickets EventTicket[]
  transactions Transaction[]

  @@index([email])
  @@map("users")
}

model Content {
  id           String         @id @default(uuid())
  title        String
  description  String?        @db.Text
  genre        String[]
  year         Int?
  rating       Decimal?       @db.Decimal(3, 2)
  duration     String
  thumbnail_url String
  backdrop_url String?
  local_thumbnail_url String?  // For uploaded thumbnails
  local_backdrop_url String?   // For uploaded backdrops
  video_url    String?
  trailer_url  String?
  cast         Json
  type         ContentType
  featured     Boolean        @default(false)
  created_at   DateTime       @default(now())

  // HLS Transcoding Fields
  hls_video_id        String?          @db.Uuid
  hls_url             String?
  hls_cdn_url         String?
  transcoding_status  String?          @default("pending")
  transcoded_at       DateTime?

  watchlist    Watchlist[]
  watch_progress WatchProgress[]
  rental_price RentalPrice?
  rentals      UserRental[]

  @@index([featured])
  @@index([type])
  @@index([hls_video_id])
  @@index([transcoding_status])
  @@map("contents")
}

model Watchlist {
  id         String   @id @default(uuid())
  user_id    String
  content_id String
  added_at   DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content    Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
  @@index([user_id, content_id])
  @@map("watchlists")
}

model WatchProgress {
  id              String   @id @default(uuid())
  user_id         String
  content_id      String
  progress_seconds Int
  last_watched    DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content         Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
  @@map("watch_progress")
}

model LiveEvent {
  id              String      @id @default(uuid())
  title           String
  description     String?     @db.Text
  event_type      EventType
  scheduled_at    DateTime
  duration_minutes Int?
  thumbnail_url   String
  backdrop_url    String?
  local_thumbnail_url String?
  local_backdrop_url String?
  stream_key      String
  host_name       String?
  is_live         Boolean     @default(false)
  ticket_price    Decimal?    @db.Decimal(10, 2)  // Harga tiket event (nullable jika gratis)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  tickets         EventTicket[]

  @@index([scheduled_at])
  @@index([is_live])
  @@map("live_events")
}

// ============ LIVE STREAMING BROADCAST ============

enum BroadcastStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model BroadcastEvent {
  id              String         @id @default(uuid())
  title           String
  description     String?        @db.Text
  scheduled_time  DateTime       @default(now())
  category        String         // "Sports", "Music", "Education", "Gaming", etc
  chat_enabled    Boolean        @default(true)
  status          BroadcastStatus @default(SCHEDULED)

  // IVS Credentials (hardcoded from environment)
  stream_key      String
  rtmp_url        String
  playback_url    String

  viewer_count    Int            @default(0)
  started_at      DateTime?
  ended_at        DateTime?
  created_by      String?        // Optional: user yang buat event

  // Relationships
  chat_messages   ChatMessage[]

  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  @@index([status])
  @@index([scheduled_time])
  @@index([category])
  @@map("broadcast_events")
}

model ChatMessage {
  id              String         @id @default(uuid())
  broadcast_id    String
  username        String         // "Viewer" atau username user (kalau logged in)
  message         String         @db.Text
  is_host_message Boolean        @default(false)  // True kalau dari broadcaster

  created_at      DateTime       @default(now())

  // Relationship
  broadcast       BroadcastEvent @relation(fields: [broadcast_id], references: [id], onDelete: Cascade)

  @@index([broadcast_id])
  @@index([created_at])
  @@map("chat_messages")
}

// ============ PAYMENT SYSTEM ============

enum PaymentType {
  RENTAL
  SUBSCRIPTION
  EVENT_TICKET
}

enum PaymentStatus {
  PENDING
  SETTLEMENT
  FAILED
  EXPIRED
  REFUND
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// Paket subscription
model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   // "VOD Unlimited"
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  duration_days Int      // 30 for monthly
  features      Json     // {"vod": true, "live_discount": 0}
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// User subscriptions
model UserSubscription {
  id              String             @id @default(uuid())
  user_id         String
  plan_id         String
  status          SubscriptionStatus @default(ACTIVE)
  started_at      DateTime           @default(now())
  expired_at      DateTime
  auto_renew      Boolean            @default(true)
  cancelled_at    DateTime?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  user            User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan   @relation(fields: [plan_id], references: [id])
  transactions    Transaction[]

  @@index([user_id])
  @@index([status])
  @@map("user_subscriptions")
}

// Harga rental per content
model RentalPrice {
  id              String   @id @default(uuid())
  content_id      String   @unique
  price           Decimal  @db.Decimal(10, 2)
  duration_hours  Int      // 24 jam
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  content         Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)
  rentals         UserRental[]

  @@map("rental_prices")
}

// User rentals
model UserRental {
  id              String      @id @default(uuid())
  user_id         String
  content_id      String
  rental_price_id String
  rented_at       DateTime    @default(now())
  expired_at      DateTime
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content         Content     @relation(fields: [content_id], references: [id], onDelete: Cascade)
  rental_price    RentalPrice @relation(fields: [rental_price_id], references: [id])
  transaction     Transaction @relation(fields: [transaction_id], references: [id])
  transaction_id  String      @unique

  @@index([user_id, content_id])
  @@index([expired_at])
  @@map("user_rentals")
}

// Event tickets
model EventTicket {
  id              String      @id @default(uuid())
  user_id         String
  event_id        String
  purchased_at    DateTime    @default(now())
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event           LiveEvent   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  transaction     Transaction @relation(fields: [transaction_id], references: [id])
  transaction_id  String      @unique

  @@unique([user_id, event_id])
  @@index([user_id])
  @@map("event_tickets")
}

// Unified transaction table
model Transaction {
  id                      String         @id @default(uuid())
  user_id                 String
  order_id                String         @unique  // Format: ORD-timestamp-random
  payment_type            PaymentType
  amount                  Decimal        @db.Decimal(10, 2)
  status                  PaymentStatus  @default(PENDING)
  payment_method          String?        // gopay, bank_transfer, qris, etc
  midtrans_transaction_id String?        @unique
  midtrans_token          String?
  subscription_id         String?
  metadata                Json?          // Store additional info
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  user                    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subscription            UserSubscription? @relation(fields: [subscription_id], references: [id])
  rental                  UserRental?
  event_ticket            EventTicket?

  @@index([user_id])
  @@index([status])
  @@index([order_id])
  @@map("transactions")
}

