// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  MOVIE
  SERIES
}

enum EventType {
  GALA_PREMIERE
  STANDUP_COMEDY
  CONCERT
  SPECIAL_EVENT
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password_hash String
  full_name    String?
  avatar_url   String?
  local_avatar_url String?    // For uploaded avatars
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  watchlist    Watchlist[]
  watch_progress WatchProgress[]

  @@index([email])
  @@map("users")
}

model Content {
  id           String         @id @default(uuid())
  title        String
  description  String?        @db.Text
  genre        String[]
  year         Int?
  rating       Decimal?       @db.Decimal(3, 2)
  duration     String
  thumbnail_url String
  backdrop_url String?
  local_thumbnail_url String?  // For uploaded thumbnails
  local_backdrop_url String?   // For uploaded backdrops
  video_url    String?
  trailer_url  String?
  cast         Json
  type         ContentType
  featured     Boolean        @default(false)
  created_at   DateTime       @default(now())
  watchlist    Watchlist[]
  watch_progress WatchProgress[]

  @@index([featured])
  @@index([type])
  @@map("contents")
}

model Watchlist {
  id         String   @id @default(uuid())
  user_id    String
  content_id String
  added_at   DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content    Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
  @@index([user_id, content_id])
  @@map("watchlists")
}

model WatchProgress {
  id              String   @id @default(uuid())
  user_id         String
  content_id      String
  progress_seconds Int
  last_watched    DateTime @default(now())
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content         Content  @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
  @@map("watch_progress")
}

model LiveEvent {
  id              String      @id @default(uuid())
  title           String
  description     String?     @db.Text
  event_type      EventType
  scheduled_at    DateTime
  duration_minutes Int?
  thumbnail_url   String
  backdrop_url    String?
  local_thumbnail_url String?
  local_backdrop_url String?
  stream_key      String
  host_name       String?
  is_live         Boolean     @default(false)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@index([scheduled_at])
  @@index([is_live])
  @@map("live_events")
}

