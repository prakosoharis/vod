	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-refresh token if it's about to expire",
					"const token = pm.collectionVariables.get('userToken');",
					"if (token) {",
					"    try {",
					"        const payload = JSON.parse(atob(token.split('.')[1]));",
					"        const expirationTime = payload.exp * 1000;",
					"        const currentTime = Date.now();",
					"        ",
					"        // If token expires within next 5 minutes, show warning",
					"        if (expirationTime - currentTime < 300000) {",
					"            console.log('⚠️ Token will expire soon. Consider re-authenticating.');",
					"        }",
					"    } catch (e) {",
					"        console.log('Invalid token format');",
					"    }",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global response time monitoring",
					"const responseTime = pm.response.responseTime;",
					"pm.test(`⏱️ Response time: ${responseTime}ms`);",
					"",
					"// Log environment info",
					"console.log(`🌐 Base URL: ${pm.collectionVariables.get('baseUrl')}`);",
					"console.log(`📧 User: ${pm.collectionVariables.get('userEmail') || 'Not authenticated'}`);"
				]
			}
		}
