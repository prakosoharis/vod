				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('userEmail', pm.response.json().email);",
									"    pm.collectionVariables.set('userToken', pm.response.json().token);",
									"    pm.test(\"✅ User registered successfully\");",
									"    pm.test(\"📧 Email saved: \" + pm.collectionVariables.get('userEmail'));",
									"} else {",
									"    pm.test(\"❌ Registration failed\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
