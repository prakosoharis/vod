# ================================================================
# HLS TRANSCODER - PRODUCTION ENVIRONMENT CONFIGURATION
# ================================================================
# IMPORTANT: Copy this file to .env.production and update with secure values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# SECURITY NOTICE:
# - NEVER commit .env.production to git (already in .gitignore)
# - Use strong, unique passwords for production
# - Rotate credentials regularly
# ================================================================

# ================================================================
# MinIO Configuration (S3 Compatible Storage)
# ================================================================
# CRITICAL: Change these from defaults!
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=Password!123

# MinIO Connection (for backend)
# IMPORTANT: These credentials must match MINIO_ROOT_USER and MINIO_ROOT_PASSWORD above
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Password!123
MINIO_USE_SSL=false

# MinIO Advanced Settings
MINIO_BROWSER=on
MINIO_PROMETHEUS_AUTH_TYPE=public

# ================================================================
# Bucket Names
# ================================================================
TEMP_BUCKET=temp-raw-aws
PERM_BUCKET=perm-storage-wasabi

# ================================================================
# Backend Configuration
# ================================================================
NODE_ENV=production
PORT=5000

# Public CDN URL (for generating response URLs)
# This should be your public domain
CDN_BASE_URL=https://transcode.mostara.id

# ================================================================
# Optional: Advanced Settings
# ================================================================
# Logging level
LOG_LEVEL=info

# FFmpeg settings (if applicable)
# FFMPEG_THREADS=4
# FFMPEG_PRESET=medium

# Upload limits
# MAX_FILE_SIZE=5368709120  # 5GB in bytes

# ================================================================
# Server Information (for documentation only)
# ================================================================
# SERVER_IP=161.97.65.21
# DOMAINS=transcode.mostara.id,minio.mostara.id
# SSL_PROVIDER=cloudflare
# DEPLOYMENT_DATE=2025-01-XX
