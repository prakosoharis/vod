# ============================================================================
# HLS Transcoder Integration - Environment Variables
# ============================================================================
# Add these to your existing apps/backend/.env file

# HLS Transcoder Service URL
TRANSCODER_URL=http://localhost:5000

# Or if running in production/different server:
# TRANSCODER_URL=http://transcoder-service:5000

# App Base URL (for generating playback URLs)
APP_URL=http://localhost:8080

# ============================================================================
# Optional: If you want to proxy HLS URLs through your backend
# ============================================================================

# HLS CDN Base URL (public-facing URL for video streaming)
HLS_CDN_URL=http://localhost:8080

# Or in production:
# HLS_CDN_URL=https://cdn.yourdomain.com
